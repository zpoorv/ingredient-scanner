rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasAdminRoleDocument() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.admin == true || hasAdminRoleDocument());
    }

    function isShortString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function isNullableString(value, maxLen) {
      return value == null || (value is string && value.size() <= maxLen);
    }

    function isNullableInt(value, minValue, maxValue) {
      return value == null || (value is int && value >= minValue && value <= maxValue);
    }

    function isNullableNumber(value, minValue, maxValue) {
      return value == null || (value is number && value >= minValue && value <= maxValue);
    }

    function isNullableStringList(value, maxItems) {
      return value == null || (value is list && value.size() <= maxItems);
    }

    function isClientScannedProductCreate(product, barcode) {
      return product.keys().hasAll([
          'additiveTags',
          'allergens',
          'barcode',
          'categories',
          'code',
          'createdAt',
          'labels',
          'name',
          'nutrition',
          'productNameSearch',
          'product_name',
          'searchKeywords',
          'sourceType',
          'updatedAt'
        ])
        && product.keys().hasOnly([
          'additiveTags',
          'allergens',
          'barcode',
          'brand',
          'categories',
          'code',
          'createdAt',
          'ecoScore',
          'imageUrl',
          'ingredientsText',
          'labels',
          'name',
          'novaGroup',
          'nutrition',
          'nutriScore',
          'productNameSearch',
          'product_name',
          'quantity',
          'searchKeywords',
          'sourceType',
          'updatedAt'
        ])
        && product.sourceType == 'scan'
        && product.barcode == barcode
        && isShortString(product.barcode, 80)
        && isShortString(product.code, 80)
        && isShortString(product.createdAt, 64)
        && isShortString(product.updatedAt, 64)
        && isShortString(product.name, 180)
        && isShortString(product.product_name, 180)
        && isShortString(product.productNameSearch, 180)
        && isNullableString(product.brand, 160)
        && isNullableString(product.ecoScore, 32)
        && isNullableString(product.imageUrl, 500)
        && isNullableString(product.ingredientsText, 6000)
        && isNullableString(product.nutriScore, 32)
        && isNullableString(product.quantity, 120)
        && isNullableInt(product.novaGroup, 1, 4)
        && isNullableStringList(product.additiveTags, 40)
        && isNullableStringList(product.allergens, 40)
        && isNullableStringList(product.categories, 40)
        && isNullableStringList(product.labels, 40)
        && isNullableStringList(product.searchKeywords, 80)
        && product.nutrition is map
        && product.nutrition.keys().hasOnly([
          'calories100g',
          'carbohydrates100g',
          'fat100g',
          'fiber100g',
          'potassium100g',
          'protein100g',
          'salt100g',
          'saturatedFat100g',
          'sodium100g',
          'sugar100g'
        ])
        && isNullableNumber(product.nutrition.calories100g, 0, 5000)
        && isNullableNumber(product.nutrition.carbohydrates100g, 0, 1000)
        && isNullableNumber(product.nutrition.fat100g, 0, 1000)
        && isNullableNumber(product.nutrition.fiber100g, 0, 1000)
        && isNullableNumber(product.nutrition.potassium100g, 0, 1000)
        && isNullableNumber(product.nutrition.protein100g, 0, 1000)
        && isNullableNumber(product.nutrition.salt100g, 0, 1000)
        && isNullableNumber(product.nutrition.saturatedFat100g, 0, 1000)
        && isNullableNumber(product.nutrition.sodium100g, 0, 1000)
        && isNullableNumber(product.nutrition.sugar100g, 0, 1000);
    }

    function isScanHistoryWrite(entry, uid) {
      return isOwner(uid)
        && entry.keys().hasAll([
          'barcode',
          'firstScannedAt',
          'gradeLabel',
          'id',
          'name',
          'product',
          'profileId',
          'riskLevel',
          'riskSummary',
          'scanCount',
          'scannedAt',
          'score',
          'productTimeline'
        ])
        && entry.keys().hasOnly([
          'barcode',
          'barcodeType',
          'firstScannedAt',
          'gradeLabel',
          'id',
          'name',
          'product',
          'profileId',
          'riskLevel',
          'riskSummary',
          'scanCount',
          'scannedAt',
          'score',
          'productTimeline'
        ])
        && isShortString(entry.barcode, 80)
        && isNullableString(entry.barcodeType, 32)
        && isShortString(entry.firstScannedAt, 64)
        && isNullableString(entry.gradeLabel, 4)
        && isShortString(entry.id, 80)
        && isShortString(entry.name, 180)
        && isShortString(entry.profileId, 40)
        && entry.product is map
        && (entry.riskLevel == 'safe' || entry.riskLevel == 'caution' || entry.riskLevel == 'high-risk')
        && isShortString(entry.riskSummary, 240)
        && entry.scanCount is int
        && entry.scanCount >= 1
        && entry.scanCount <= 5000
        && isShortString(entry.scannedAt, 64)
        && isNullableInt(entry.score, 0, 100)
        && entry.productTimeline is list
        && entry.productTimeline.size() <= 12;
    }

    function isCorrectionReportCreate(report) {
      return isVerifiedUser()
        && report.keys().hasAll([
          'barcode',
          'confidence',
          'createdAt',
          'foodStatus',
          'priorityScore',
          'productName',
          'reason',
          'reporterEmail',
          'reporterName',
          'reporterUid',
          'resultSource',
          'status',
          'summary',
          'topConcern'
        ])
        && report.keys().hasOnly([
          'barcode',
          'confirmationCount',
          'confidence',
          'createdAt',
          'foodStatus',
          'priorityScore',
          'productName',
          'reason',
          'repeatBuyWeight',
          'reportType',
          'reporterEmail',
          'reporterName',
          'reporterUid',
          'resultSource',
          'status',
          'summary',
          'timelineSeverity',
          'topConcern',
          'trustConfirmationType'
        ])
        && report.reporterUid == request.auth.uid
        && report.reporterEmail == request.auth.token.email
        && isNullableString(report.reporterName, 120)
        && isShortString(report.barcode, 80)
        && isShortString(report.createdAt, 64)
        && isShortString(report.productName, 180)
        && isShortString(report.summary, 240)
        && isNullableString(report.topConcern, 120)
        && (report.confidence == 'high' || report.confidence == 'medium' || report.confidence == 'low')
        && (
          report.foodStatus == 'food' ||
          report.foodStatus == 'likely-food' ||
          report.foodStatus == 'unclear' ||
          report.foodStatus == 'non-food'
        )
        && (
          report.reason == 'wrong-score' ||
          report.reason == 'wrong-product-details' ||
          report.reason == 'bad-ingredient-read' ||
          report.reason == 'wrong-alternatives' ||
          report.reason == 'other'
        )
        && (report.resultSource == 'barcode' || report.resultSource == 'ingredient-ocr')
        && report.status == 'open'
        && report.priorityScore is int
        && report.priorityScore >= 0
        && report.priorityScore <= 200
        && isNullableInt(report.confirmationCount, 0, 5000)
        && isNullableInt(report.repeatBuyWeight, 0, 5000)
        && (
          !report.keys().hasAny(['reportType']) ||
          report.reportType == 'issue-report' ||
          report.reportType == 'trust-confirmation'
        )
        && (
          !report.keys().hasAny(['timelineSeverity']) ||
          report.timelineSeverity == null ||
          report.timelineSeverity == 'low' ||
          report.timelineSeverity == 'medium' ||
          report.timelineSeverity == 'high'
        )
        && (
          !report.keys().hasAny(['trustConfirmationType']) ||
          report.trustConfirmationType == null ||
          report.trustConfirmationType == 'looks-different' ||
          report.trustConfirmationType == 'matches-pack'
        );
    }

    function isOwnerProfileCreate(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == 'user'
        && request.resource.data.plan == 'free';
    }

    function isOwnerProfileUpdate(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role == resource.data.role
        && request.resource.data.plan == resource.data.plan;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwnerProfileCreate(uid) || isAdmin();
      allow update: if isOwnerProfileUpdate(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();

      match /scanHistory/{scanId} {
        allow read, delete: if isOwner(uid) || isAdmin();
        allow create, update: if isScanHistoryWrite(request.resource.data, uid) || isAdmin();
      }
    }

    // Shared product records power search. Admins can fully manage them, while scans can seed
    // a tightly constrained record for future Firestore-backed lookups.
    match /products/{barcode} {
      allow read: if true;
      allow create: if isAdmin() || isClientScannedProductCreate(request.resource.data, barcode);
      allow update: if isAdmin()
        || (
          resource.data.sourceType == 'scan'
          && request.resource.data.sourceType == 'scan'
          && isClientScannedProductCreate(request.resource.data, barcode)
        );
      allow delete: if isAdmin();
    }

    // Legacy collection kept admin-only for backwards compatibility.
    match /productOverrides/{barcode} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /adminConfig/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Feedback stays admin-readable and can later back a support dashboard.
    match /feedback/{feedbackId} {
      allow create: if isVerifiedUser();
      allow read, update, delete: if isAdmin();
    }

    match /correctionReports/{reportId} {
      allow create: if isCorrectionReportCreate(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
